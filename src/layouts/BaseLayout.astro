---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
    title = "Stratton Digital Systems",
    description = "Performance-focused websites for service businesses.",
    pageClass = "",
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />

        <title>{title}</title>
        <meta name="description" content={description} />

        <!-- Google tag (gtag.js) -->
        <script
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-3Q4NZB9PPR"
        ></script>
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                window.dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", "G-3Q4NZB9PPR");
        </script>

        <!-- Structured Data -->
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "ProfessionalService",
                "name": "Stratton Digital Systems",
                "url": "https://strattondigitalsystems.com",
                "description": "Website design and development for service businesses. Platform builds, custom builds, and ongoing website management.",
                "areaServed": {
                    "@type": "Country",
                    "name": "United States"
                }
            }
        </script>

        <!-- Canonical -->
        <link rel="canonical" href={Astro.url.href} />

        <!-- Favicons -->
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

        <!-- Open Graph -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url.href} />

        <!-- Optional but safe -->
        <meta name="robots" content="index, follow" />
    </head>

    <body class={pageClass}>
        <Header />
        <main>
            <slot />
        </main>
        <Footer />
    </body>
</html>
